# Python / notebooks
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Логи и служебные артефакты запусков
logs/
artifacts/
archives/

# Исходные данные соревнования кладутся локально перед запуском.
# В GitHub их обычно не коммитим из-за размера и правил соревнований.
train.csv
test.csv
sample_submition.csv

# Промежуточные CSV/JSON создаются pipeline в корне проекта.
submission*.csv
local_valid*.csv
test_*.csv
kaggle_*debug*.csv
*_results.json
*_results_debug.csv

# Но финальные curated-версии для отчёта храним в отдельных папках.
!submissions/
!submissions/*.csv
!reports/
!reports/*.json

# Большие embedding/cache файлы
*.npy
*.npz

# Обученные модели и AutoGluon-папки
rubert_salary*/
rubert_large_salary*/
bert_inference_tmp/
autogluon*/

# Локальные pretrained-модели или junction-папки.
# Они нужны для запуска, но в GitHub не загружаются.
rubert_large_base/
ruroberta_large_base/
xlm_roberta_large_base/

# Основные файлы проекта остаются видимыми.
!README.md
!FILES_TO_SUBMIT.txt
!requirements.txt
!TETA_NN1_FINAL_HOMEWORK.ipynb
!run_all.py
!pipeline/
!pipeline/**/*.py
!tools/
!tools/*.py
